# Servidor
PORT=3000
HOST=0.0.0.0

# Clave de API del Proxy. Déjala vacía para permitir peticiones sin autenticación.
API_KEY=

# Credenciales de Qwen para el login automático e inicialización del pool.
QWEN_EMAIL=
QWEN_PASSWORD=

# Establécelo en 'true' para ignorar la rotación de cuentas y usar solo el modo invitado.
QWEN_GUEST_MODE_ONLY=false

# Enlaces base de Qwen.
QWEN_BASE_URL=https://chat.qwen.ai
QWEN_HTTP_ENDPOINT=https://api.qwen.ai/v1/chat

# Clave de API opcional para el endpoint HTTP de Qwen.
QWEN_API_KEY=

# Configuración del navegador de Playwright.
BROWSER=chromium
HEADLESS=true
USER_DATA_DIR=./qwen_profiles
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
LOG_CONSOLE=false

# Reducción de riesgo anti-bot (tiempos de vida y refrescos).
HEADERS_TTL_MS=1800000
BACKGROUND_HEADER_REFRESH=false
WARM_POOL_SIZE=0
WARM_POOL_LOW_WATER=0
WARM_POOL_TTL_MS=600000
WARM_POOL_STARTUP=false
SESSION_KEEPER_ENABLED=false
ACCOUNT_INIT_CONCURRENCY=2
ACCOUNT_INIT_STAGGER_MIN_MS=300
ACCOUNT_INIT_STAGGER_MAX_MS=900
PRECAPTURE_HEADERS_STARTUP=false
PRECAPTURE_HEADERS_CONCURRENCY=1
PRECAPTURE_HEADERS_STAGGER_MIN_MS=2500
PRECAPTURE_HEADERS_STAGGER_MAX_MS=5000

# Usar una sola cuenta dividida en múltiples carriles de Playwright para concurrencia.
SINGLE_ACCOUNT_MODE=false
SINGLE_ACCOUNT_ID=
SINGLE_ACCOUNT_EMAIL=
ACCOUNT_LANES=1

# Tiempos límite (milisegundos).
NAVIGATION_TIMEOUT=45000
PAGE_TIMEOUT=30000
HTTP_TIMEOUT=30000
HEADERS_TIMEOUT=60000
CHAT_TIMEOUT=120000
STREAM_IDLE_TIMEOUT=180000

# Tiempos de caché (segundos).
CACHE_TTL=3600
RESPONSE_TTL=1800

# Intervalo de recolección de métricas (milisegundos).
METRICS_INTERVAL=10000

# Configuración de Watchdog (vigilante).
WATCHDOG_INTERVAL=5000
WATCHDOG_FAILURES=3
RAM_WARNING=80
RAM_CRITICAL=95
WS_WARNING=50
WS_CRITICAL=100
